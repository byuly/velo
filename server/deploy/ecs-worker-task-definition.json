{
  "family": "velo-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/veloTaskRole",
  "containerDefinitions": [
    {
      "name": "worker",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/velo-api:latest",
      "essential": true,
      "command": ["/usr/local/bin/worker"],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/velo-worker",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "worker"
        }
      },
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/velo/DATABASE_URL"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/velo/JWT_SECRET"
        }
      ],
      "environment": [
        { "name": "LOG_LEVEL", "value": "info" },
        { "name": "APPLE_APP_ID", "value": "com.example.app" },
        { "name": "AWS_REGION", "value": "us-west-2" },
        { "name": "S3_CLIPS_BUCKET", "value": "velo-clips" },
        { "name": "S3_REELS_BUCKET", "value": "velo-reels" },
        { "name": "CLOUDFRONT_DOMAIN", "value": "cdn.example.com" }
      ]
    }
  ]
}
